# image-proxy — Environment Variables Example
# Copy this file to .dev.vars for local development with wrangler

# [REQUIRED] Bearer token for accessing your private R2 or Backblaze B2 bucket
BUCKET_ACCESS_TOKEN=your_bucket_access_token_here

# [OPTIONAL] Zorvik tenant verification API base URL
# Fallback: https://api.zorvik.com/api/v1/verify
LICENSE_API_BASE=https://api.zorvik.com/api/v1/verify
