# image-proxy — Environment Variables Example
# Copy this file to .dev.vars for local development with wrangler

# [REQUIRED] Supabase project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase service role key (for management schema access)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
