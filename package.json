{
  "name": "wedding-image-proxy",
  "version": "0.7.8",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for secure, dynamic image watermarking via Cloudflare Image Resizing.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "lint": "eslint src test --max-warnings 0",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "wrangler deploy --dry-run",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.45.0",
    "aws4fetch": "^1.0.20"
  }
}
